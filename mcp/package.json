{
  "name": "@anythinggraph/cli-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP layer for AnythingGraph CLI reasoning-service (Rust core)",
  "bin": {
    "anythinggraph-cli-mcp": "./dist/index.js",
    "anythinggraph-cli-mcp-http": "./dist/http.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "build": "npm run build:stdio && npm run build:http",
    "build:stdio": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external --banner:js=#!/usr/bin/env\\ node",
    "build:http": "esbuild src/http.ts --bundle --platform=node --format=esm --outfile=dist/http.js --packages=external --banner:js=#!/usr/bin/env\\ node",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
