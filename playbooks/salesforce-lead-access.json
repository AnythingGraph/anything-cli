{
  "id": "salesforce-lead-access",
  "name": "Salesforce lead access",
  "description": "CRM users and leads in Salesforce (User + Lead objects).",
  "entities": {
    "crm_user": {
      "id": "user_id",
      "fields": ["full_name"]
    },
    "crm_lead": {
      "id": "lead_id",
      "fields": ["lead_name"]
    }
  },
  "relationships": {
    "assigned_to": { "from": "crm_user", "to": "crm_lead" }
  },
  "sources": {
    "crm_user": "salesforce",
    "crm_lead": "salesforce"
  },
  "access": {
    "summary": "CRM users read leads assigned to them (Lead.OwnerId).",
    "subject": "crm_user",
    "subject_id": "user_id",
    "allow": [
      { "relationship": "assigned_to", "resource": "crm_lead" }
    ]
  }
}
