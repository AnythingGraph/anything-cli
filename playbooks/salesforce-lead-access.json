{
  "id": "salesforce-lead-access",
  "name": "Salesforce lead access",
  "description": "Salesforce user sees leads assigned to them.",
  "entities": {
    "crm_user": {
      "identifier": "user_id",
      "attributes": ["full_name"]
    },
    "crm_lead": {
      "identifier": "lead_id",
      "attributes": ["lead_name"]
    }
  },
  "relationships": {
    "assigned_to": { "from": "crm_user", "to": "crm_lead" }
  },
  "sources": {
    "crm_user": "salesforce",
    "crm_lead": "salesforce"
  },
  "access": {
    "summary": "Sales users read leads assigned to them.",
    "subject": "crm_user",
    "subject_id": "user_id",
    "allow": [
      { "relationship": "assigned_to", "resource": "crm_lead" }
    ]
  }
}
