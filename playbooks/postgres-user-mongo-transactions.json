{
  "id": "postgres-user-mongo-transactions",
  "name": "Postgres Users + Mongo Transactions",
  "description": "Cross-source playbook linking Postgres users (user_id) to MongoDB transactions (userID).",
  "entities": {
    "crm_user": {
      "identifier": "user_id",
      "attributes": [
        "full_name"
      ]
    },
    "transaction": {
      "identifier": "transaction_id",
      "attributes": [
        "amount",
        "currency",
        "paymentMethod",
        "status",
        "sku"
      ]
    }
  },
  "relationships": {
    "made_by_user": {
      "from": "transaction",
      "to": "crm_user"
    }
  },
  "sources": {
    "crm_user": "postgres",
    "transaction": "mongodb"
  }
}