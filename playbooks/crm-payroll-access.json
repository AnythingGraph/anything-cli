{
  "id": "crm-payroll-access",
  "name": "CRM + payroll access",
  "description": "Extends simple CRM: sales users and accounts in Postgres; payroll history in a CSV file. One playbook, two bindings (postgres + csv).",
  "category": "start_here",
  "instructions": "1. Create Postgres users/accounts tables (same as simple-crm-access).\n2. Sample payroll CSV at ag-cli/data/payroll.csv (column `user`, not user_id).\n3. bindings map: postgres → crm-payroll-access.postgres, csv → crm-payroll-access.csv.\n4. Omit binding_name on queries — runtime routes from count object entity via entity_sources.\n5. owns_account (object crm_account) → postgres; user_has_payroll (object crm_payroll_record) → csv.",
  "entities": [
    {
      "name": "crm_user",
      "display_name": "CRM user",
      "fields": [
        { "field_name": "user_id", "field_type": "TEXT", "is_identifier": true },
        { "field_name": "full_name", "field_type": "TEXT" }
      ]
    },
    {
      "name": "crm_account",
      "display_name": "Account",
      "fields": [
        { "field_name": "account_name", "field_type": "TEXT", "is_identifier": true },
        { "field_name": "industry", "field_type": "TEXT" }
      ]
    },
    {
      "name": "crm_payroll_record",
      "display_name": "Payroll record",
      "fields": [
        { "field_name": "payroll_id", "field_type": "TEXT", "is_identifier": true },
        { "field_name": "user_id", "field_type": "TEXT", "description": "Links to crm_user.user_id" },
        { "field_name": "pay_period", "field_type": "TEXT" },
        { "field_name": "gross_pay", "field_type": "TEXT" },
        { "field_name": "currency", "field_type": "TEXT" },
        { "field_name": "pay_date", "field_type": "TEXT" }
      ]
    }
  ],
  "entity_relationships": [
    {
      "relationship_name": "owns_account",
      "subject_entity_name": "crm_user",
      "object_entity_name": "crm_account"
    },
    {
      "relationship_name": "user_has_payroll",
      "subject_entity_name": "crm_user",
      "object_entity_name": "crm_payroll_record"
    }
  ],
  "entity_sources": {
    "crm_user": "postgres",
    "crm_account": "postgres",
    "crm_payroll_record": "csv"
  },
  "field_mappings": {
    "payroll_csv": {
      "crm_user": {
        "user_id": "user"
      },
      "crm_payroll_record": {
        "user_id": "user"
      }
    },
    "warehouse_pg": {
      "crm_user": {
        "user_id": "user_id"
      },
      "crm_account": {
        "account_name": "account_name"
      }
    }
  },
  "bindings": {
    "postgres": "crm-payroll-access.postgres",
    "csv": "crm-payroll-access.csv"
  },
  "default_binding": "crm-payroll-access.postgres"
}
