{
  "id": "mongo_postgres_playbook",
  "name": "Mongo Postgres Playbook",
  "description": "Links Postgres users (user_id) to MongoDB transactions (userID).",
  "entities": {
    "crm_user": {
      "identifier": "user_id",
      "attributes": [
        "full_name"
      ]
    },
    "transaction": {
      "identifier": "transaction_id",
      "attributes": [
        "amount",
        "currency",
        "status",
        "payment_method",
        "sku",
        "user_id"
      ]
    }
  },
  "relationships": {
    "made_by_user": {
      "from": "transaction",
      "to": "crm_user"
    }
  },
  "sources": {
    "crm_user": "postgres",
    "transaction": "mongodb"
  }
}