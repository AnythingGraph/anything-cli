{
  "id": "simple-crm-access",
  "name": "Simple CRM access",
  "description": "Minimal local playbook: sales reps and the accounts they own (Postgres users + accounts tables).",
  "entities": {
    "crm_user": {
      "id": "user_id",
      "fields": ["full_name"]
    },
    "crm_account": {
      "id": "account_name",
      "fields": ["industry"]
    }
  },
  "relationships": {
    "owns_account": { "from": "crm_user", "to": "crm_account" }
  },
  "sources": {
    "crm_user": "postgres",
    "crm_account": "postgres"
  },
  "access": {
    "summary": "CRM users read only accounts they own.",
    "subject": "crm_user",
    "subject_id": "user_id",
    "allow": [
      { "relationship": "owns_account", "resource": "crm_account" }
    ]
  }
}
