{
  "id": "crm-example",
  "name": "CRM example",
  "description": "Example playbook: CRM users and accounts in Postgres only (warehouse_pg).",
  "entities": {
    "crm_user": {
      "identifier": "user_id",
      "attributes": ["full_name"]
    },
    "crm_account": {
      "identifier": "account_name",
      "attributes": ["industry"]
    }
  },
  "relationships": {
    "owns_account": {
      "from": "crm_user",
      "to": "crm_account"
    }
  },
  "sources": {
    "crm_user": "postgres",
    "crm_account": "postgres"
  },
  "access": {
    "summary": "CRM users read accounts they own.",
    "subject": "crm_user",
    "subject_id": "user_id",
    "allow": [
      {
        "relationship": "owns_account",
        "resource": "crm_account"
      }
    ]
  }
}
