# Anything CLI — local credentials and service settings
#
# Setup:
#   cp .env.example .env
#   # edit .env with your values (never commit .env)
#   ./start-all.sh          # loads .env automatically when present
#
# Or load manually in your shell:
#   set -a && source .env && set +a && ./start-all.sh
#
# profiles/local.yaml references these vars as env:AG_* — keep secrets here,
# not in playbooks, bindings, or git.

# -----------------------------------------------------------------------------
# Data source credentials (profiles/local.yaml)
# -----------------------------------------------------------------------------

# Postgres — profile key warehouse_pg (adapter: sql)
AG_SQL_DSN=postgres://user:pass@localhost:5432/yourdb

# Local CSV — profile key payroll_csv (adapter: csv)
# Default in start-all.sh is ./data/payroll.csv if unset
AG_PAYROLL_CSV_PATH=./data/payroll.csv

# MongoDB — profile key mongo_main (adapter: mongodb)
AG_MONGODB_DSN=mongodb://localhost:27017
AG_MONGODB_DATABASE=mydb

# Salesforce — profile key salesforce_main (adapter: soql)
AG_SF_INSTANCE_URL=https://your-instance.my.salesforce.com
AG_SF_ACCESS_TOKEN=

# REST / HTTP JSON API — add to profiles/local.yaml as api_main if needed
# AG_REST_BASE_URL=https://api.example.com
# AG_REST_TOKEN=

# -----------------------------------------------------------------------------
# MCP and reasoning-service (optional — defaults work for local dev)
# -----------------------------------------------------------------------------

# AG_WORKSPACE_ROOT=          # set automatically by start-all.sh
# AG_REASONING_HOST=127.0.0.1
# AG_REASONING_PORT=8787
# AG_REASONING_URL=http://127.0.0.1:8787
# AG_MCP_HOST=127.0.0.1
# AG_MCP_PORT=3334

# Local dev: auth disabled by default (start-all.sh sets AG_AUTH_DISABLED=1)
# To enable bearer tokens, set AG_AUTH_DISABLED=0 and uncomment:
# AG_AUTH_DISABLED=0
# AG_ADMIN_TOKENS=admin-secret-change-me
# AG_USER_TOKENS=user-secret-change-me
# AG_MCP_AUTH_TOKEN=admin-secret-change-me

# -----------------------------------------------------------------------------
# Debug (optional)
# -----------------------------------------------------------------------------

# AG_DEBUG_COMPILED=1         # include compiled binding YAML in propose_binding responses
